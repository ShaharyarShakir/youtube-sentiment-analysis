{
  "panels": [
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "uid": "prometheus"
          },
          "expr": "rate(http_requests_total{job=\"fastapi\"}[5m])",
          "legendFormat": "{{handler}} {{status}}"
        }
      ],
      "title": "Requests per second",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"fastapi\"}[5m]))",
          "legendFormat": "{{handler}}"
        }
      ],
      "title": "Request latency p95",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "uid": "prometheus"
          },
          "expr": "rate(http_requests_total{job=\"fastapi\", status=~\"5xx\"}[5m])",
          "legendFormat": "{{handler}}"
        }
      ],
      "title": "Error rate",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "uid": "prometheus"
          },
          "expr": "sum by (handler) (http_requests_total{job=\"fastapi\"})",
          "legendFormat": "{{handler}}"
        }
      ],
      "title": "Total requests by endpoint",
      "type": "bargauge"
    }
  ],
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "FastAPI Metrics",
  "uid": "fastapi-metrics",
  "version": 1
}
